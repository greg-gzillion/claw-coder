import os
import subprocess
import json
import glob
import re
from datetime import datetime
from groq import Groq

GROQ_API_KEY = os.environ.get("GROQ_API_KEY")
client = Groq(api_key=GROQ_API_KEY) if GROQ_API_KEY else None

# ============ CONFIGURATION ============
PROJECT_ROOT = "/home/greg/dev/TX"
PERMISSION_MODE = "read-only"  # read-only, workspace-write, full
CURRENT_MODEL = "llama-3.3-70b-versatile"

# ============ SESSION MANAGEMENT ============
SESSION_DIR = os.path.expanduser("~/.claw_sessions")
os.makedirs(SESSION_DIR, exist_ok=True)
current_session = None
session_data = {"conversations": [], "created": None, "total_cost": 0, "total_tokens": 0}

def session_new(name=None):
    global current_session, session_data
    if not name:
        name = f"session_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
    current_session = name
    session_data = {
        "id": name,
        "created": datetime.now().isoformat(),
        "conversations": [],
        "total_cost": 0,
        "total_tokens": 0,
        "permission_mode": PERMISSION_MODE
    }
    session_save()
    print(f"New session: {name}")

def session_save():
    if current_session:
        path = os.path.join(SESSION_DIR, f"{current_session}.json")
        with open(path, 'w') as f:
            json.dump(session_data, f, indent=2)

def session_load(name):
    global current_session, session_data
    path = os.path.join(SESSION_DIR, f"{name}.json")
    if os.path.exists(path):
        with open(path, 'r') as f:
            session_data = json.load(f)
        current_session = name
        print(f"Loaded session: {name} ({len(session_data.get('conversations', []))} messages)")
        return True
    print(f"Session not found: {name}")
    return False

def session_list():
    sessions = glob.glob(os.path.join(SESSION_DIR, "*.json"))
    if not sessions:
        print("No saved sessions")
        return
    print("\nSaved sessions:")
    for s in sessions:
        name = os.path.basename(s).replace('.json', '')
        with open(s, 'r') as f:
            data = json.load(f)
            print(f"  {name} - {len(data.get('conversations', []))} messages")

def session_compact():
    if current_session:
        convs = session_data.get('conversations', [])
        if len(convs) > 20:
            old = len(convs)
            session_data['conversations'] = convs[-20:]
            session_save()
            print(f"Compacted: {old} -> 20 messages")
        else:
            print(f"Only {len(convs)} messages, no compaction needed")

def session_export(filename=None):
    if not filename:
        filename = f"export_{current_session}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
    with open(filename, 'w') as f:
        json.dump(session_data, f, indent=2)
    print(f"Exported to: {filename}")

# ============ TOOLS (ported from claw-code) ============
def tool_read(filepath):
    """Read a file from the project"""
    if PERMISSION_MODE == "read-only" or PERMISSION_MODE == "workspace-write" or PERMISSION_MODE == "full":
        full_path = os.path.join(PROJECT_ROOT, filepath.lstrip('/'))
        if os.path.exists(full_path):
            with open(full_path, 'r') as f:
                content = f.read()
                lines = len(content.split('\n'))
                print(f"\n[Reading {filepath} - {lines} lines]\n")
                return content[:5000]
        return f"File not found: {filepath}"
    return "Permission denied (read-only mode)"

def tool_write(filepath, content):
    """Write to a file (requires workspace-write or full permission)"""
    if PERMISSION_MODE == "workspace-write" or PERMISSION_MODE == "full":
        full_path = os.path.join(PROJECT_ROOT, filepath.lstrip('/'))
        os.makedirs(os.path.dirname(full_path), exist_ok=True)
        with open(full_path, 'w') as f:
            f.write(content)
        return f"Written to {filepath}"
    return "Permission denied (requires workspace-write or full)"

def tool_glob(pattern):
    """Find files matching pattern"""
    matches = glob.glob(os.path.join(PROJECT_ROOT, pattern), recursive=True)
    return '\n'.join([m.replace(PROJECT_ROOT, '') for m in matches[:20]])

def tool_grep(pattern, file_pattern="*.rs"):
    """Search for pattern in files"""
    cmd = f"grep -rn '{pattern}' {PROJECT_ROOT} --include='{file_pattern}' 2>/dev/null | head -30"
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    return result.stdout if result.stdout else f"No matches for '{pattern}'"

def tool_git_diff():
    """Show git diff"""
    result = subprocess.run(f"cd {PROJECT_ROOT} && git diff --stat", shell=True, capture_output=True, text=True)
    return result.stdout if result.stdout else "No changes"

def tool_git_status():
    """Show git status"""
    result = subprocess.run(f"cd {PROJECT_ROOT} && git status -s", shell=True, capture_output=True, text=True)
    return result.stdout if result.stdout else "Working tree clean"

