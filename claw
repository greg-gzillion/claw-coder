import os
import subprocess
from groq import Groq

GROQ_API_KEY = os.environ.get("GROQ_API_KEY")
client = Groq(api_key=GROQ_API_KEY) if GROQ_API_KEY else None

def ask_with_context(question):
    """Ask AI with relevant code context"""
    if not client:
        return "Set GROQ_API_KEY for fast responses"
    
    # Always include escrow.rs for collateral questions
    context_files = []
    
    # Find relevant files based on question keywords
    keywords = question.lower().split()
    for kw in keywords:
        if kw in ['collateral', 'escrow', 'dual', 'lock']:
            if os.path.exists('/home/greg/dev/TX/escrow.rs'):
                context_files.append('/home/greg/dev/TX/escrow.rs')
            if os.path.exists('/home/greg/dev/TX/tests/generated_tests.rs'):
                context_files.append('/home/greg/dev/TX/tests/generated_tests.rs')
            break
    
    # If no specific files found, search for relevant ones
    if not context_files:
        for kw in keywords[:2]:
            result = subprocess.run(f"grep -l '{kw}' /home/greg/dev/TX/*.rs 2>/dev/null | head -1",
                                   shell=True, capture_output=True, text=True)
            if result.stdout.strip():
                context_files.append(result.stdout.strip())
    
    # Build context from files
    context = ""
    for filepath in context_files[:2]:
        if filepath and os.path.exists(filepath):
            with open(filepath, 'r') as f:
                content = f.read()
                # Get relevant sections (around keywords)
                lines = content.split('\n')
                relevant_lines = []
                for i, line in enumerate(lines):
                    for kw in keywords[:2]:
                        if kw in line.lower():
                            start = max(0, i-5)
                            end = min(len(lines), i+6)
                            relevant_lines.extend(lines[start:end])
                            break
                    if len(relevant_lines) > 50:
                        break
                
                if relevant_lines:
                    context += f"\n=== {os.path.basename(filepath)} ===\n"
                    context += '\n'.join(relevant_lines[:60])
                    context += "\n"
    
    # If no context found, provide basic info
    if not context:
        context = "PhoenixPME escrow system with 10% collateral from both parties."
    
    prompt = f"""You are a PhoenixPME blockchain expert. Use this code context:

{context}

Question: {question}

Answer based on the actual code above. Be specific - mention actual values like 10%, 1.1%, 48 hours, and reference the actual functions seen in the code."""
    
    try:
        completion = client.chat.completions.create(
            model="llama-3.3-70b-versatile",
            messages=[{"role": "user", "content": prompt}],
            max_tokens=1500
        )
        return completion.choices[0].message.content
    except Exception as e:
        return f"API Error: {e}"

def search_project(term):
    """Search TX project for term"""
    cmd = f"grep -rn '{term}' /home/greg/dev/TX --include='*.rs' --include='*.md' 2>/dev/null | head -25"
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    return result.stdout if result.stdout else f"No results found for '{term}'"

print("\n" + "="*50)
print("🦞 CLAW - PhoenixPME AI Assistant")
if GROQ_API_KEY:
    print("🚀 FAST MODE (Groq) - 1-2 second responses")
else:
    print("⚠️  Set GROQ_API_KEY for fast responses")
print("="*50)
print("Commands: ask | search | status | token | exit")
print("="*50)

while True:
    try:
        cmd = input("\n🦞 ").strip()
        if not cmd:
            continue
        if cmd == "exit":
            break
        elif cmd == "status":
            print("\n🏛️ PHOENIXPME")
            print("  Fee: 1.1%")
            print("  Collateral: 10% (both parties)")
            print("  Inspection: 48 hours")
            print("  PHNX: 1 per $1 TESTUSD fees")
        elif cmd == "token":
            print("\n🪙 TESTUSD Token")
            print("  Network: Coreum testnet")
            print("  Denom: utestusd-testcore1tymxlev27p5rhxd36g4j3a82c7uucjjz4xuzc6")
            print("  Decimals: 6")
        elif cmd.startswith("ask "):
            print("🤔 Thinking...")
            answer = ask_with_context(cmd[4:])
            print(f"\n{answer}\n")
        elif cmd.startswith("search "):
            print(search_project(cmd[7:]))
        else:
            print("Commands: ask <question> | search <term> | status | token | exit")
    except KeyboardInterrupt:
        break

print("\nGoodbye!")
