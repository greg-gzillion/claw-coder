# ============ COST TRACKING ============
def track_cost(prompt_tokens, completion_tokens):
    input_cost = (prompt_tokens / 1_000_000) * 0.59
    output_cost = (completion_tokens / 1_000_000) * 0.79
    total = input_cost + output_cost
    session_data['total_cost'] = session_data.get('total_cost', 0) + total
    session_data['total_tokens'] = session_data.get('total_tokens', 0) + prompt_tokens + completion_tokens
    session_save()
    return total

def show_cost():
    print(f"\nSession: {current_session}")
    print(f"  Messages: {len(session_data.get('conversations', []))}")
    print(f"  Total tokens: {session_data.get('total_tokens', 0)}")
    print(f"  Total cost: ${session_data.get('total_cost', 0):.6f}")

# ============ AI QUERY ============
def read_project_file(filename):
    paths = [
        f"{PROJECT_ROOT}/{filename}",
        f"{PROJECT_ROOT}/docs/{filename}",
        f"{PROJECT_ROOT}/docs/business/{filename}",
    ]
    for path in paths:
        if os.path.exists(path):
            with open(path, 'r') as f:
                return f.read()
    return None

def ask_ai(question):
    if not client:
        return "ERROR: GROQ_API_KEY not set"
    
    context = ""
    question_lower = question.lower()
    
    vision_keywords = ['phnx', 'trust', 'vision', 'token', 'governance', 'reputation']
    if any(kw in question_lower for kw in vision_keywords):
        content = read_project_file("VISION.md")
        if content:
            context += f"\n[VISION.md - PhoenixPME Tokenomics]\n{content[:4000]}\n"
            print("(Reading VISION.md for context...)")
    
    auction_keywords = ['auction', 'escrow', 'collateral', 'bid']
    if any(kw in question_lower for kw in auction_keywords):
        content = read_project_file("contracts/auction/src/contract/mod.rs")
        if content:
            context += f"\n[Auction Contract]\n{content[:2000]}\n"
            print("(Reading auction contract for context...)")
    
    if context:
        prompt = f"""You are a PhoenixPME blockchain expert. Use ONLY the provided file content.

{context}

Question: {question}

Answer based strictly on the content above."""
    else:
        prompt = question
    
    try:
        completion = client.chat.completions.create(
            model=CURRENT_MODEL,
            messages=[{"role": "user", "content": prompt}],
            max_tokens=1500
        )
        response = completion.choices[0].message.content
        prompt_tokens = len(prompt) // 4
        response_tokens = len(response) // 4
        track_cost(prompt_tokens, response_tokens)
        
        session_data.setdefault('conversations', []).append({
            'question': question,
            'answer': response[:500],
            'timestamp': datetime.now().isoformat()
        })
        session_save()
        
        return response
    except Exception as e:
        return f"API Error: {e}"

# ============ SEARCH ============
def search_project(term):
    term = term.strip('"\'')
    cmd = f"grep -rn '{term}' {PROJECT_ROOT} --include='*.rs' --include='*.md' 2>/dev/null | head -30"
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    return result.stdout if result.stdout else f"No results found for: {term}"

# ============ PERMISSION MODES ============
def set_permission(mode):
    global PERMISSION_MODE
    if mode in ["read-only", "workspace-write", "full"]:
        PERMISSION_MODE = mode
        session_data['permission_mode'] = mode
        session_save()
        print(f"Permission mode: {mode}")
        if mode == "read-only":
            print("  Can only read files")
        elif mode == "workspace-write":
            print("  Can read and write files in workspace")
        else:
            print("  Full system access - be careful")
    else:
        print("Modes: read-only, workspace-write, full")

def show_status():
    print(f"\nSession: {current_session}")
    print(f"Messages: {len(session_data.get('conversations', []))}")
    print(f"Permission: {PERMISSION_MODE}")
    print(f"Model: {CURRENT_MODEL}")
    print(f"Cost: ${session_data.get('total_cost', 0):.6f}")
    print(f"\nProject: {PROJECT_ROOT}")
    print(f"Groq API: {'Connected' if client else 'Not set'}")

# ============ MAIN ============
session_new()

print("\n" + "="*60)
print("🦞 CLAW - PhoenixPME AI Assistant")
print("Ported features: Tools, Permissions, Git, Web Search")
if GROQ_API_KEY:
    print(f"FAST MODE (Groq) - Model: {CURRENT_MODEL}")
else:
    print("Set GROQ_API_KEY for fast responses")
print("="*60)
print("\nCOMMANDS:")
print("  ask <question>          - Ask about your code")
print("  search <term>           - Search codebase")
print("  read <file>             - Read a file")
print("  grep <pattern>          - Search code with grep")
print("  git status|diff         - Git integration")
print("  permission <mode>       - Set permission level")
print("  model <name>            - Switch Groq model")
print("  session new|list|load|compact|export")
print("  cost                    - Show token/cost usage")
print("  status                  - Show system status")
print("  exit                    - Quit")
print("="*60)

while True:
    try:
        cmd = input("\n🦞 ").strip()
        if not cmd:
            continue
        
        if cmd == "exit":
            session_save()
            print(f"Session saved: {current_session}")
            break
        
        elif cmd == "status":
            show_status()
        
        elif cmd == "cost":
            show_cost()
        
        elif cmd.startswith("permission "):
            set_permission(cmd.split()[1])
        
        elif cmd.startswith("model "):
            new_model = cmd.split()[1]
            CURRENT_MODEL = new_model
            print(f"Model switched to: {CURRENT_MODEL}")
        
        elif cmd.startswith("read "):
            print(tool_read(cmd[5:]))
        
        elif cmd.startswith("grep "):
            parts = cmd.split()
            pattern = parts[1] if len(parts) > 1 else ""
            file_pattern = parts[2] if len(parts) > 2 else "*.rs"
            print(tool_grep(pattern, file_pattern))
        
        elif cmd == "git status":
            print(tool_git_status())
        
        elif cmd == "git diff":
            print(tool_git_diff())
        
        elif cmd.startswith("session "):
            parts = cmd.split()
            if len(parts) < 2:
                print("session new|list|load <name>|compact|export")
            elif parts[1] == "new":
                name = parts[2] if len(parts) > 2 else None
                session_new(name)
            elif parts[1] == "list":
                session_list()
            elif parts[1] == "load" and len(parts) > 2:
                session_load(parts[2])
            elif parts[1] == "compact":
                session_compact()
            elif parts[1] == "export":
                filename = parts[2] if len(parts) > 2 else None
                session_export(filename)
            else:
                print("Unknown session command")
        
        elif cmd.startswith("ask "):
            question = cmd[4:]
            print("Thinking...")
            answer = ask_ai(question)
            print(f"\n{answer}\n")
        
        elif cmd.startswith("search "):
            term = cmd[7:]
            print(search_project(term))
        
        else:
            print("Unknown command. Try: ask, search, read, grep, git, permission, model, session, cost, status, exit")
            
    except KeyboardInterrupt:
        print("\nGoodbye!")
        session_save()
        break
    except Exception as e:
        print(f"Error: {e}")

print("Goodbye!")
