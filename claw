#!/usr/bin/env python3
"""
🦞 CLAW - PhoenixPME AI Assistant
"""

import os
import subprocess
from groq import Groq

GROQ_API_KEY = os.environ.get("GROQ_API_KEY")
client = Groq(api_key=GROQ_API_KEY) if GROQ_API_KEY else None

def read_file(filepath):
    """Read a file and return its contents"""
    full_path = f"/home/greg/dev/TX/{filepath}"
    if os.path.exists(full_path):
        with open(full_path, 'r') as f:
            return f.read()
    return None

def ask_ai(question):
    if not client:
        return "ERROR: GROQ_API_KEY not set. Run: export GROQ_API_KEY='your-key'"
    
    # Check if question asks about a specific file
    context = ""
    file_patterns = {
        'VISION.md': ['vision', 'VISION.md'],
        'README.md': ['readme', 'README'],
        'CLAW.md': ['claw', 'CLAW'],
        'escrow.rs': ['escrow'],
    }
    
    for filename, keywords in file_patterns.items():
        if any(kw in question.lower() for kw in keywords):
            content = read_file(filename)
            if content:
                context += f"\n=== {filename} ===\n{content[:3000]}\n"
                break
    
    # Also try to extract filename from question
    words = question.split()
    for word in words:
        if word.endswith('.md') or word.endswith('.rs'):
            content = read_file(word)
            if content:
                context += f"\n=== {word} ===\n{content[:3000]}\n"
                break
    
    if context:
        prompt = f"""You are a PhoenixPME blockchain expert. Here is the actual file content:

{context}

Question: {question}

Answer based ONLY on the file content above. Be specific and quote from the file."""
    else:
        prompt = question
    
    try:
        completion = client.chat.completions.create(
            model="llama-3.3-70b-versatile",
            messages=[{"role": "user", "content": prompt}],
            max_tokens=1500
        )
        return completion.choices[0].message.content
    except Exception as e:
        return f"API Error: {e}"

def search_project(term):
    term = term.strip('"\'')
    cmd = f"grep -rn '{term}' /home/greg/dev/TX --include='*.rs' --include='*.md' --include='*.txt' 2>/dev/null | head -30"
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    
    if result.stdout:
        return result.stdout
    else:
        return f"No results found for: {term}"

print("\n" + "="*50)
print("🦞 CLAW - PhoenixPME AI Assistant")
if GROQ_API_KEY:
    print("FAST MODE (Groq) - 1-2 second responses")
else:
    print("SLOW MODE - Set GROQ_API_KEY for fast responses")
print("="*50)
print("Commands: ask | search | status | token | exit")
print("="*50)

while True:
    try:
        cmd = input("\n🦞 ").strip()
        if not cmd:
            continue
        
        if cmd == "exit":
            break
        elif cmd == "status":
            print("\nPHOENIXPME")
            print("  Fee: 1.1% -> PHNX tokens")
            print("  Collateral: 10% from both parties")
            print("  Inspection: 48 hours")
            print("  Token: TESTUSD on Coreum testnet")
        elif cmd == "token":
            print("\nTESTUSD Token")
            print("  Network: Coreum testnet")
            print("  Decimals: 6")
        elif cmd.startswith("ask "):
            question = cmd[4:]
            print("Thinking...")
            answer = ask_ai(question)
            print(f"\n{answer}\n")
        elif cmd.startswith("search "):
            term = cmd[7:]
            print(search_project(term))
        else:
            print("Commands: ask <question> | search <term> | status | token | exit")
            
    except KeyboardInterrupt:
        print("\nGoodbye!")
        break
    except Exception as e:
        print(f"Error: {e}")

print("Goodbye!")
