#!/usr/bin/env python3
"""
🦞 DUAL CLAW - Groq API (fast) + Ollama (fallback)
"""

import requests
import os
import subprocess
import time

# Try Groq first
GROQ_AVAILABLE = False
GROQ_API_KEY = os.environ.get("GROQ_API_KEY")

if GROQ_API_KEY:
    try:
        from groq import Groq
        groq_client = Groq(api_key=GROQ_API_KEY)
        GROQ_AVAILABLE = True
        print("✅ Groq API available (FAST mode)")
    except:
        pass

if not GROQ_AVAILABLE:
    print("⚠️ Groq not configured - using Ollama (SLOW mode)")
    print("   Get free API key: https://console.groq.com")
    print("   Then: export GROQ_API_KEY='your-key'")

# Ollama config
OLLAMA_URL = "http://localhost:11434/api/generate"
OLLAMA_MODEL = "llama3.2:3b"

def ask_groq(prompt):
    """Lightning fast - 0.5-2 seconds"""
    try:
        completion = groq_client.chat.completions.create(
            model="llama-3.3-70b-versatile",
            messages=[{"role": "user", "content": prompt}],
            temperature=0.5,
            max_tokens=2000
        )
        return completion.choices[0].message.content, "Groq (fast)"
    except Exception as e:
        return f"Groq error: {e}", None

def ask_ollama(prompt):
    """Slow fallback - 2-3 minutes"""
    try:
        start = time.time()
        r = requests.post(OLLAMA_URL,
            json={"model": OLLAMA_MODEL, "prompt": prompt, "stream": False},
            timeout=180)
        elapsed = time.time() - start
        if r.status_code == 200:
            return r.json()["response"], f"Ollama ({elapsed:.0f}s)"
        return f"Ollama error: {r.status_code}", None
    except Exception as e:
        return f"Ollama error: {e}", None

def ask_ai(prompt):
    """Try Groq first, fallback to Ollama"""
    if GROQ_AVAILABLE:
        response, source = ask_groq(prompt)
        if source:
            print(f"⚡ [{source}]")
            return response
    
    print("🐌 [Ollama fallback - this will take 2-3 minutes]")
    response, source = ask_ollama(prompt)
    if source:
        print(f"🐌 [{source}]")
        return response
    return "No AI backend available"

def quick_search(directory, pattern, max_results=15):
    """Fast grep search"""
    try:
        result = subprocess.run(
            f"timeout 10 grep -rn '{pattern}' {directory} 2>/dev/null | head -{max_results}",
            shell=True, capture_output=True, text=True, timeout=12
        )
        return result.stdout if result.stdout else "No results found"
    except:
        return "Search timeout"

print("\n" + "="*60)
print("🦞 DUAL CLAW - Groq (fast) + Ollama (fallback)")
print("="*60)
if GROQ_AVAILABLE:
    print("🚀 PRIMARY: Groq API - 0.5-2 second responses")
    print("🐌 FALLBACK: Ollama - 2-3 minutes (offline mode)")
else:
    print("⚠️  Groq not configured - using Ollama only")
    print("   Get API key: export GROQ_API_KEY='your-key'")
print("="*60)
print("\nCommands: ask | docsearch | codesearch | analyze | chat | prices | status | mode | exit")
print("="*60)

while True:
    try:
        cmd = input("\n🦞 ").strip()
        if not cmd:
            continue
        
        if cmd == "exit":
            break
        
        elif cmd == "prices":
            print("\n🏛️ METAL PRICES")
            print("  Gold: $4,676 | Silver: $72.90")
            print("  Platinum: $1,980 | Palladium: $1,490")
        
        elif cmd == "status":
            print("\n🏛️ PHOENIXPME STATUS")
            print("  Fee: 1.1% | Collateral: 10%")
            print("  Inspection: 48h | PHNX: 1 per $1")
            if GROQ_AVAILABLE:
                print("  🤖 AI: Groq (fast mode)")
            else:
                print("  🤖 AI: Ollama (slow mode)")
        
        elif cmd == "mode":
            if GROQ_AVAILABLE:
                print("Current: Groq API (fast)")
                print("To use Ollama: unset GROQ_API_KEY")
            else:
                print("Current: Ollama (slow)")
                print("To use Groq: export GROQ_API_KEY='your-key'")
        
        elif cmd.startswith("ask "):
            question = cmd[4:]
            print("\n🤔 Thinking...")
            response = ask_ai(question)
            print(f"\n{response}\n")
        
        elif cmd.startswith("docsearch "):
            term = cmd[10:]
            print(f"\n🔍 Searching TX documentation...")
            print(quick_search("/home/greg/dev/TXdocumentation", term))
        
        elif cmd.startswith("codesearch "):
            term = cmd[11:]
            print(f"\n🔍 Searching TX code...")
            print(quick_search("/home/greg/dev/TX", term))
        
        elif cmd.startswith("analyze "):
            path = os.path.expanduser(cmd[8:])
            if os.path.exists(path):
                with open(path, 'r') as f:
                    code = f.read()[:2000]
                print("\n🤔 Analyzing code...")
                response = ask_ai(f"Explain this Rust/CosmWasm code:\n\n{code}")
                print(f"\n{response}\n")
            else:
                print(f"Not found: {path}")
        
        elif cmd == "chat":
            print("\n💬 Chat mode (type 'exit' to return)")
            while True:
                q = input("You: ").strip()
                if q.lower() == "exit":
                    break
                if q:
                    print("🤔...")
                    response = ask_ai(q)
                    print(f"\n{response}\n")
        
        else:
            print("Commands: ask | docsearch | codesearch | analyze | chat | prices | status | mode | exit")
            
    except KeyboardInterrupt:
        print("\nGoodbye!")
        break
    except Exception as e:
        print(f"Error: {e}")

if __name__ == "__main__":
    main()
